#!/bin/sh
set -eu

canonical_dir() {
	cd "$1" && pwd -P
}

hook_dir="$(canonical_dir "$(dirname "$0")")"
workspace_root="$(canonical_dir "$hook_dir/..")"
repo_root="$(canonical_dir "$(git rev-parse --show-toplevel 2>/dev/null || pwd)")"

# The root zWorkspaces repository may push directly to main/master, but a project
# PR merged through guarded-pr-merge leaves local closeout debt. Root pushes stay
# blocked until docs/kb, Notion links, and ticket completion are committed.
if [ "$repo_root" = "$workspace_root" ]; then
	checked_ref=0
	zero_sha=0000000000000000000000000000000000000000
	while read local_ref local_sha remote_ref remote_sha; do
		if [ "$local_sha" != "$zero_sha" ]; then
			python3 "$workspace_root/runbooks/compound_workflow_gate.py" \
				pending-closeouts --ref "$local_sha"
			checked_ref=1
		fi
	done
	if [ "$checked_ref" -eq 0 ]; then
		python3 "$workspace_root/runbooks/compound_workflow_gate.py" \
			pending-closeouts --ref HEAD
	fi
	exit 0
fi

protected=" ${MAIN_GUARD_BRANCHES:-main master} "
is_protected_ref() {
	ref="$1"
	name="${ref#refs/heads/}"
	case "$protected" in
		*" $name "*) return 0 ;;
		*) return 1 ;;
	esac
}
while read local_ref local_sha remote_ref remote_sha; do
	if is_protected_ref "$local_ref" || is_protected_ref "$remote_ref"; then
		if [ "${MAIN_GUARD_APPROVED:-}" != "1" ]; then
			cat >&2 <<'MSG'

⛔ main-guard: protected project branch push blocked.

Project repositories under projects/ must not push directly to main/master.
Preferred workflow: create/confirm a ticket, work on a branch, and open a PR/MR.
The root zWorkspaces repository is exempt and may push directly to main.

If the user explicitly approved this exact project main-branch push, rerun only
that command with:

  MAIN_GUARD_APPROVED=1 git push ...

MSG
			exit 1
		fi
	fi
done
