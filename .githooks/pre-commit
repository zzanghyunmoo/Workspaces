#!/bin/sh
set -eu
branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
protected=" ${MAIN_GUARD_BRANCHES:-main master} "
case "$protected" in
  *" $branch "*)
    if [ "${MAIN_GUARD_APPROVED:-}" != "1" ]; then
      cat >&2 <<'MSG'

⛔ main-guard: protected branch commit blocked.

This workspace requires explicit user approval before committing directly on main/master.
Preferred workflow: create/confirm a ticket, work on a branch, and open a PR.
If the user explicitly approved this exact main-branch commit, rerun only that command with:

  MAIN_GUARD_APPROVED=1 git commit ...

MSG
      exit 1
    fi
    ;;
esac
