FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY . .
RUN dotnet restore DevAutomation.sln \
    && dotnet publish src/DevAutomation.ApprovalMcp/DevAutomation.ApprovalMcp.csproj -c Release -o /out/mcp --no-restore

FROM mcr.microsoft.com/dotnet/runtime:8.0 AS agent
# hadolint ignore=DL3008,DL3016
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates git gh nodejs npm \
    && npm install -g @anthropic-ai/claude-code \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=build /out/mcp ./
ENTRYPOINT ["/bin/sh", "-lc"]
